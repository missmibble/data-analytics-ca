# AWS
AWS_REGION=ca-central-1

# S3
S3_BUCKET_RAW=foresite-raw-ca
S3_BUCKET_DOCS=foresite-docs-ca

# Redshift Serverless
REDSHIFT_WORKGROUP=foresite-wg
REDSHIFT_DATABASE=foresite

# Bedrock Knowledge Base (populated by infra/setup.py after provisioning)
STRUCTURED_KB_ID=

# CORS — set to * during development; update to external site URL when known
# Multiple origins: comma-separated, e.g. https://site-a.com,https://site-b.com
ALLOWED_ORIGINS=*

# API Gateway invoke URL (populated by infra/setup.py after provisioning)
API_GATEWAY_URL=

# Lambda Function URL for streaming chat (populated by infra/setup.py after provisioning)
STREAM_URL=
